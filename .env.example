# Required: get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# VLM configuration
VLM_MODEL=claude-sonnet-4-6
VLM_MAX_RETRIES=3

# Timing (seconds)
ACTION_DELAY=0.5
NOTEPAD_LAUNCH_TIMEOUT=10

# Paths
SCREENSHOT_DIR=screenshots
LOG_DIR=logs
PROJECT_DIR_NAME=tjm-project

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
