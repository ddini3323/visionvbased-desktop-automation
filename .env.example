# Anthropic API key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Corporate / local proxy (auto-detected when set, overrides API key)
# ANTHROPIC_BASE_URL=http://localhost:PORT/anthropic/
# ANTHROPIC_AUTH_TOKEN=your-proxy-token
# VLM configuration (Stage 4 fallback)
VLM_MODEL=claude-sonnet-latest
VLM_MAX_RETRIES=3
# Output directories (auto-created)
SCREENSHOT_DIR=screenshots
LOG_DIR=logs
PROJECT_DIR_NAME=tjm-project
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Fix Windows console encoding errors (recommended)
# Set this in your shell before running:  $env:PYTHONUTF8 = "1"